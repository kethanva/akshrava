POSTGRES_PASSWORD=replace-with-a-long-random-password
# Pilot/production require RS256. Keep the matching private key only on the provisioning
# workstation (JWT_PRIVATE_KEY_FILE), never on the API host.
JWT_ALGORITHM=RS256
JWT_KEY_DIR=../secrets/jwt
JWT_PUBLIC_KEY_FILE=/run/secrets/jwt/device-public.pem
JWT_PRIVATE_KEY_FILE=../secrets/jwt/device-private.pem
# Required outside development so /metrics is not public (Prometheus uses Bearer scrape).
METRICS_SCRAPE_TOKEN=replace-with-a-long-random-metrics-token
AKSHRAVA_ENV=pilot
DETECTOR=noop
# Diagnostic GCS uploads stay off until a face/plate blur pipeline exists (PRIVACY.md).
DIAGNOSTIC_UPLOADS_ENABLED=false
# Set both only after the model licence, accuracy and latency gate has passed.
INSTALL_YOLO=false
MODEL_DIR=../models
YOLO_WEIGHTS=/models/yolo11s.pt
DEV_AUTH_BYPASS=false
MIN_FRAME_INTERVAL_MS=200
ALERT_MAX_AGE_MS=500
ALERT_RETENTION_DAYS=30
READY_TIMEOUT_MS=2000
INFERENCE_TIMEOUT_MS=800
INFERENCE_EXECUTOR_WORKERS=2
MAX_ACTIVE_SESSIONS=200
DATABASE_SCHEMA_REVISION=20260719_01
# Required for central replay/session coordination; use an independent high-entropy secret.
# Prefer URL-safe characters (A-Za-z0-9-_) so redis://:PASSWORD@host parses; GCP URLs are urlencoded.
REDIS_PASSWORD=replace-with-a-long-random-redis-password
# Leave these unset to use the Compose-private authenticated Redis URLs.
REDIS_URL=
NONCE_REDIS_URL=
# For a split deployment, set DETECTOR=remote on the control plane and configure the private
# HTTPS/WireGuard endpoint of api-gpu. The shared secret must be at least 32 characters.
REMOTE_INFERENCE_URL=
REMOTE_WORKER_SECRET=
REMOTE_INFERENCE_TIMEOUT_MS=450
# Mutually authenticated TLS material for remote GPU workers. Mount the containing host directory
# as WORKER_MTLS_DIR and use these in pilot/production remote deployments.
WORKER_MTLS_DIR=../secrets/worker-mtls
REMOTE_TLS_CA_FILE=/run/secrets/worker-mtls/ca.pem
REMOTE_TLS_CLIENT_CERT_FILE=/run/secrets/worker-mtls/client.pem
REMOTE_TLS_CLIENT_KEY_FILE=/run/secrets/worker-mtls/client-key.pem
GPU_WORKER_BIND_ADDRESS=127.0.0.1
WORKER_REQUEST_MAX_AGE_SECONDS=30
# Cloud image fallback is opt-in. Local detection always runs first; cloud runs only when it is empty.
# Choose exactly one: none, aws, gcp, azure. Build credentials are supplied by the host identity.
CLOUD_FALLBACK_PROVIDER=none
CLOUD_MIN_CONFIDENCE=0.55
AWS_REGION=
AZURE_VISION_ENDPOINT=
AZURE_VISION_KEY=
DOMAIN=vision.example.org
# Required by Compose configuration; keep it in the deployment secret store.
GRAFANA_PASSWORD=replace-with-a-long-random-grafana-password
