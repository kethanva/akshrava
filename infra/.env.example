POSTGRES_PASSWORD=replace-with-a-long-random-password
JWT_SECRET=replace-with-a-long-random-secret
AKSHRAVA_ENV=pilot
DETECTOR=noop
# Set both only after the model licence, accuracy and latency gate has passed.
INSTALL_YOLO=false
MODEL_DIR=../models
YOLO_WEIGHTS=/models/yolo11s.pt
DEV_AUTH_BYPASS=false
MIN_FRAME_INTERVAL_MS=200
ALERT_MAX_AGE_MS=500
ALERT_RETENTION_DAYS=30
READY_TIMEOUT_MS=2000
# For a split deployment, set DETECTOR=remote on the control plane and configure the private
# HTTPS/WireGuard endpoint of api-gpu. The shared secret must be at least 32 characters.
REMOTE_INFERENCE_URL=
REMOTE_WORKER_SECRET=
REMOTE_INFERENCE_TIMEOUT_MS=450
GPU_WORKER_BIND_ADDRESS=127.0.0.1
WORKER_REQUEST_MAX_AGE_SECONDS=30
# Cloud image fallback is opt-in. Local detection always runs first; cloud runs only when it is empty.
# Choose exactly one: none, aws, gcp, azure. Build credentials are supplied by the host identity.
CLOUD_FALLBACK_PROVIDER=none
CLOUD_MIN_CONFIDENCE=0.55
AWS_REGION=
AZURE_VISION_ENDPOINT=
AZURE_VISION_KEY=
DOMAIN=vision.example.org
# Required by Compose configuration; keep it in the deployment secret store.
GRAFANA_PASSWORD=replace-with-a-long-random-grafana-password
